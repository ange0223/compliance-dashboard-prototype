<script>
const tooltip = document.createElement("div");
tooltip.className = "custom-tooltip";
document.body.appendChild(tooltip);

document.addEventListener("mouseover", function (e) {
  const target = e.target.closest("[data-tooltip]");
  if (!target) return;

  tooltip.textContent = target.dataset.tooltip;
  tooltip.style.opacity = "1";

  const rect = target.getBoundingClientRect();
  tooltip.style.left = "0px";
  tooltip.style.top = "0px";
  const tw = tooltip.offsetWidth;
  const th = tooltip.offsetHeight;

  let left = rect.left + window.scrollX + rect.width / 2 - tw / 2;
  let top = rect.top + window.scrollY - th - 8;

  left = Math.max(8, Math.min(left, window.innerWidth - tw - 8));
  if (top < window.scrollY + 8) top = rect.bottom + window.scrollY + 8;

  tooltip.style.left = left + "px";
  tooltip.style.top = top + "px";
});

document.addEventListener("mouseout", function (e) {
  if (!e.target.closest("[data-tooltip]")) return;
  tooltip.style.opacity = "0";
});

$(document).ready(function () {
  $(".filter-select").select2({
    width: "100%",
    placeholder: function () {
      return $(this).data("placeholder");
    },
    allowClear: true
  });
});

const evidenceStore = {
  "3.1.1": ["Access Control Policy v2.1.pdf", "User Access Review Q1-2026.xlsx", "Active Directory Group Policy Export.pdf"],
  "3.5.3": ["MFA policy.pdf", "Authenticator enrollment report.csv"],
  "3.8.1": [],
  "3.3.1": [],
  "3.4.1": [],
  "3.6.1": [],
  "3.13.11": []
};

function requirementRow(button) {
  return button.closest("tr");
}

function requirementIdFromButton(button) {
  return requirementRow(button).dataset.requirementId;
}

function updateEvidenceCell(requirementId) {
  const rows = document.querySelectorAll(
    `[data-requirement-id="${requirementId}"]`
  );

  if (!rows.length) return;

  const evidenceCount = evidenceStore[requirementId].length;

  rows.forEach((row) => {
    const countCell = row.querySelector(".evidence-count");
    if (countCell) {
      countCell.textContent =
        `${evidenceCount} ${evidenceCount === 1 ? "File" : "Files"}`;
    }

    const actions = row.querySelector(".table-actions");
    if (!actions) return;

    if (evidenceCount > 0 && !actions.querySelector(".view-btn")) {
      actions.insertAdjacentHTML(
        "afterbegin",
        `<button class="secondary-btn view-btn">View</button>`
      );
    }

    if (evidenceCount === 0) {
      const viewButton = actions.querySelector(".view-btn");
      if (viewButton) viewButton.remove();
    }
  });
}

document.addEventListener("click", function (event) {
  const collapseButton = event.target.closest(".collapse-btn");
  const hamburgerButton = event.target.closest(".hamburger-btn");
  const sidebarOverlay = event.target.closest(".sidebar-overlay");
  const attachButton = event.target.closest(".attach-btn");
  const viewButton = event.target.closest(".view-btn");
  const exportButton = event.target.closest(".export-btn");
  const navLink = event.target.closest(".nav-link");
  const evidenceOpenButton = event.target.closest(".evidence-open-btn");
  const reportGenerateButton = event.target.closest(".report-generate-btn");
  const reportExportButton = event.target.closest(".report-export-btn");

  if (hamburgerButton) {
    document.querySelector(".app-shell").classList.add("sidebar-open");
  }

  if (sidebarOverlay) {
    document.querySelector(".app-shell").classList.remove("sidebar-open");
  }
  
  if (evidenceOpenButton) {
  Swal.fire({
    icon: "info",
    title: "Evidence Preview",
    text: "This prototype simulates opening an uploaded evidence artifact."
  });
}

if (reportGenerateButton) {
  Swal.fire({
    icon: "success",
    title: "Report Queued",
    text: `${reportGenerateButton.dataset.report} would be generated here.`
  });
}

if (reportExportButton) {
  exportRequirementsCsv();
}

  
  if (collapseButton) {
    const shell = document.querySelector(".app-shell");
    if (window.innerWidth <= 768) {
      shell.classList.remove("sidebar-open");
    } else {
      shell.classList.toggle("sidebar-collapsed");
    }
  }

  if (navLink) {
    document.querySelector(".app-shell").classList.remove("sidebar-open");
    event.preventDefault();

    document.querySelectorAll(".nav-link").forEach((link) => {
      link.classList.remove("active");
    });

    document.querySelectorAll(".content-view").forEach((view) => {
      view.classList.remove("active-view");
    });

    navLink.classList.add("active");

    document
      .getElementById(navLink.dataset.view)
      .classList.add("active-view");
  }

  if (attachButton) {
    const requirementId = requirementIdFromButton(attachButton);

    Swal.fire({
      title: `Attach Evidence to ${requirementId}`,
      customClass: {
        confirmButton: 'swal-confirm',
        cancelButton: 'swal-cancel'
      },
      html: `
        <p class="swal-copy">
          Upload a policy, screenshot, report, or audit artifact.
        </p>
        <input type="file" id="evidenceFile" class="swal2-file">
      `,
      showCancelButton: true,
      confirmButtonText: "Attach Evidence",
      preConfirm: () => {
        const fileInput = document.getElementById("evidenceFile");

        if (!fileInput.files.length) {
          Swal.showValidationMessage(
            "Please choose a file to attach."
          );
          return false;
        }

        return fileInput.files[0].name;
      }
    }).then((result) => {
      if (result.isConfirmed) {
        evidenceStore[requirementId].push(result.value);

        updateEvidenceCell(requirementId);

        Swal.fire({
          icon: "success",
          title: "Evidence Attached",
          text: `${result.value} was added to requirement ${requirementId}.`
        });
      }
    });
  }

  if (viewButton) {
    const requirementId = requirementIdFromButton(viewButton);
    const files = evidenceStore[requirementId] || [];

    const fileList = files
      .map((file, index) => `
        <div class="evidence-item">
          <span>${file}</span>

          <div>
            <button
              class="mini-btn"
              onclick="openEvidence('${file}')">
              Open
            </button>

            <button
              class="mini-btn danger"
              onclick="removeEvidence('${requirementId}', ${index})">
              Remove
            </button>
          </div>
        </div>
      `)
      .join("");

    Swal.fire({
      title: `Evidence for ${requirementId}`,
      html: fileList || "<p>No evidence attached.</p>",
      width: 700,
      showConfirmButton: false,
      showCloseButton: true
    });
  }

  if (exportButton) {
    exportRequirementsCsv();
  }
});

window.openEvidence = function (fileName) {
  Swal.fire({
    icon: "info",
    title: fileName,
    text: "This prototype simulates opening evidence."
  });
};

window.removeEvidence = function (requirementId, index) {
  evidenceStore[requirementId].splice(index, 1);

  updateEvidenceCell(requirementId);

  Swal.close();

  Swal.fire({
    icon: "success",
    title: "Evidence Removed",
    text: "The evidence item was removed."
  });
};

function exportRequirementsCsv() {
  const rows = [
    [
      "Requirement ID",
      "Requirement",
      "Status",
      "Evidence Count",
      "Evidence Files"
    ]
  ];

  document
    .querySelectorAll("#dashboard-view .requirements-table tbody tr")
    .forEach((row) => {
      const id = row.dataset.requirementId;
      const requirement = row.children[1].innerText;
      const status = row.dataset.status;
      const files = evidenceStore[id] || [];

      rows.push([
        id,
        requirement,
        status,
        files.length,
        files.join("; ")
      ]);
    });

  const csv = rows
    .map((row) =>
      row
        .map((value) =>
          `"${String(value).replaceAll('"', '""')}"`
        )
        .join(",")
    )
    .join("\n");

  const blob = new Blob([csv], {
    type: "text/csv;charset=utf-8;"
  });

  const url = URL.createObjectURL(blob);

  const link = document.createElement("a");
  link.href = url;
  link.download = "compliance-evidence-dashboard.csv";

  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);

  URL.revokeObjectURL(url);
}

function filterTable({ searchSelector, statusSelector, familySelector, tableSelector }) {
  const searchValue =
    document.querySelector(searchSelector)?.value.toLowerCase() || "";

  const selectedStatuses = $(statusSelector).val() || [];
  const selectedFamilies = $(familySelector).val() || [];

  document.querySelectorAll(`${tableSelector} tbody tr`).forEach((row) => {
    const rowText = row.innerText.toLowerCase();
    const rowStatus = row.dataset.status;
    const rowFamily = row.dataset.family;

    const matchesSearch = rowText.includes(searchValue);
    const matchesStatus =
      selectedStatuses.length === 0 || selectedStatuses.includes(rowStatus);
    const matchesFamily =
      selectedFamilies.length === 0 || selectedFamilies.includes(rowFamily);

    row.style.display =
      matchesSearch && matchesStatus && matchesFamily ? "" : "none";
  });
}

function applyDashboardFilters() {
  filterTable({
    searchSelector: ".dashboard-search",
    statusSelector: ".dashboard-status-filter",
    familySelector: ".dashboard-family-filter",
    tableSelector: "#dashboard-view .requirements-table"
  });
}

function applyRequirementsFilters() {
  filterTable({
    searchSelector: ".requirements-search",
    statusSelector: ".requirements-status-filter",
    familySelector: ".requirements-family-filter",
    tableSelector: "#requirements-view .requirements-table"
  });
}

document.addEventListener("input", function (event) {
  if (event.target.classList.contains("dashboard-search")) {
    applyDashboardFilters();
  }

  if (event.target.classList.contains("requirements-search")) {
    applyRequirementsFilters();
  }
});

$(".dashboard-status-filter, .dashboard-family-filter").on(
  "change",
  applyDashboardFilters
);

$(".requirements-status-filter, .requirements-family-filter").on(
  "change",
  applyRequirementsFilters
);</script>

